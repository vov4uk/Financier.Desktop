<core:NotificationDisplayPart x:Class="Financier.Desktop.Pages.Controls.CustomDisplayPart"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:local="clr-namespace:Financier.Desktop.Pages.Controls"
                              xmlns:core="clr-namespace:ToastNotifications.Core;assembly=ToastNotifications"
                              xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
                              mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="250" >
    <UserControl.Resources>
        <BitmapImage x:Key="ic_action_cancel"   UriSource="pack://application:,,,/Images/ic_action_cancel.png" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Background="LightGray"
                Padding="10"
                CornerRadius="5"
                Grid.ColumnSpan="2">
        <TextBlock Text="{Binding Message}" 
                   FontSize="14"
                   Foreground="Black"
                   VerticalAlignment="Stretch"
                   HorizontalAlignment="Center"/>
        </Border>
        <xctk:IconButton   Grid.Column="1"
                           Height="24"
                           Width="24"
                           VerticalAlignment="Top">
            <xctk:IconButton.Icon>
                <Image Source="{StaticResource ic_action_cancel}" />
            </xctk:IconButton.Icon>
        </xctk:IconButton>
    </Grid>
</core:NotificationDisplayPart>