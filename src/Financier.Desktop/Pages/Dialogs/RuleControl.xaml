<UserControl x:Class="Financier.Desktop.Pages.Dialogs.RuleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Financier.Desktop.Pages.Dialogs"
             xmlns:loc="clr-namespace:Financier.Common.Localization;assembly=Financier.Common"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:fcrd="clr-namespace:Financier.Common.Entities;assembly=Financier.Common"
             xmlns:converters="clr-namespace:Financier.Converters;assembly=Financier.Common"
             mc:Ignorable="d" 
             d:DesignHeight="360"
             d:DesignWidth="400">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Assets/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:InvertedBooleanToVisibilityConverter x:Key="invBoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <GroupBox Margin="5"
              Header="{loc:Translate Key=rule_details}"
              FontSize="12">
        <GroupBox.Resources>
            <Style TargetType="{x:Type Image}">
                <Setter Property="Height" Value="20" />
                <Setter Property="Width" Value="20" />
            </Style>
            <Style TargetType="{x:Type xctk:IconButton}">
                <Setter Property="Height" Value="24" />
                <Setter Property="Width" Value="24" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </GroupBox.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Margin="5" Header="{loc:Translate Key=conditions}">
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              Margin="2"
                              Height="24"
                              ItemsSource="{x:Static local:RuleControlVM.ConditionTypes}"
                              SelectedValue="{Binding SelectedConditionType}" />
                    <TextBox Grid.Column="1"
                             Margin="2"
                             Height="24"
                             FontSize="14"
                             Visibility="{Binding Path=IsMCCSelected, Converter={StaticResource invBoolToVis}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                             Text="{Binding Entity.Description}"
                             VerticalAlignment="Center"
                             />
                    <xctk:WatermarkComboBox x:Name="MCCBox"
                                            Grid.Column="1"
                                            Margin="2"
                                            IsEditable="True"
                                            Visibility="{Binding Path=IsMCCSelected, Converter={StaticResource BoolToVis}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                            ItemsSource="{Binding Source={x:Static fcrd:DbManual.MCCCategoriesKeys}, Mode=OneWay}"
                                            SelectedValue="{Binding SelectedMCC}" />
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="1" Margin="5" Header="{loc:Translate Key=actions}">
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="{loc:Translate Key=what_should_happen}"/>
                    <GroupBox Grid.Row="1"
                          Grid.Column="0"
                          Margin="5"
                          Header="{loc:Translate Key=categories}">
                        <xctk:WatermarkComboBox x:Name="CategoryIdBox"
                                                IsEditable="True"
                                                ItemsSource="{Binding Source={x:Static fcrd:DbManual.Category}, Mode=OneWay}"
                                                SelectedValuePath="Id"
                                                TextSearch.TextPath="Title"
                                                ItemTemplate="{StaticResource ResourceKey=CategoryTemplate}"
                                                SelectedItem="{Binding Entity.Category}"
                                                SelectedValue="{Binding Entity.CategoryId}"/>
                    </GroupBox>
                    <GroupBox Grid.Row="1"
                          Grid.Column="1"
                          Margin="5"
                          Header="{loc:Translate Key=locations}">
                        <xctk:WatermarkComboBox x:Name="LocationIdBox"
                                                IsEditable="True"
                                                ItemsSource="{Binding Source={x:Static fcrd:DbManual.Location}, Mode=OneWay}"
                                                SelectedValue="{Binding Entity.LocationId}"
                                                SelectedValuePath="Id"
                                                TextSearch.TextPath="Title"
                                                ItemTemplate="{StaticResource ResourceKey=IActive}" />
                    </GroupBox>
                    <GroupBox Grid.Row="2"
                          Grid.Column="0"
                          Margin="5"
                          Header="{loc:Translate Key=projects}">
                        <xctk:WatermarkComboBox x:Name="ProjectIdBox"
                                                IsEditable="True"
                                                ItemsSource="{Binding Source={x:Static fcrd:DbManual.Project}, Mode=OneWay}"
                                                SelectedValue="{Binding Entity.ProjectId}"
                                                SelectedValuePath="Id"
                                                TextSearch.TextPath="Title"
                                                ItemTemplate="{StaticResource ResourceKey=IActive}" />
                    </GroupBox>
                    <GroupBox Grid.Row="2"
                          Grid.Column="1"
                          Margin="5"
                          Header="{loc:Translate Key=payees}">
                        <xctk:WatermarkComboBox IsEditable="True"
                                                ItemsSource="{Binding Source={x:Static fcrd:DbManual.Payee}, Mode=OneWay}"
                                                SelectedValuePath="Id"
                                                TextSearch.TextPath="Title"
                                                SelectedValue="{Binding Entity.PayeeId}"
                                                ItemTemplate="{StaticResource ResourceKey=IActive}"
                                                />
                    </GroupBox>
                </Grid>
            </GroupBox>
            <CheckBox   Grid.Column="0"
                    Grid.Row="2"
                    Grid.ColumnSpan="2"
                    IsChecked="{Binding Entity.IsActive}" Content="{loc:Translate Key=is_active}" />
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Margin="2"
                        Command="{Binding SaveCommand}"
                        Content="{loc:Translate Key=save}" />
                <Button Grid.Column="1" Margin="2"
                        Command="{Binding CancelCommand}"
                        Content="{loc:Translate Key=cancel}" />
            </Grid>
        </Grid>
    </GroupBox>
</UserControl>
