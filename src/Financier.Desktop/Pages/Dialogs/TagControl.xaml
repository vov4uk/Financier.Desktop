<UserControl x:Class="Financier.Desktop.Views.Controls.TagControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:viewmodel="clr-namespace:Financier.Desktop.ViewModel.Dialog"
             xmlns:loc="clr-namespace:Financier.Common.Localization;assembly=Financier.Common"
             d:DataContext="{d:DesignInstance {x:Type viewmodel:TagControlVM}, IsDesignTimeCreatable=False}"
             mc:Ignorable="d"
             d:DesignHeight="200"
             d:DesignWidth="400">
    <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="/Assets/Generic.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
    </UserControl.Resources>
    <GroupBox Margin="5"
              Header="{loc:Translate Key=details}"
              FontSize="12">
        <GroupBox.Resources>
            <Style TargetType="{x:Type Image}">
                <Setter Property="Height" Value="20" />
                <Setter Property="Width" Value="20" />
            </Style>
            <Style TargetType="{x:Type xctk:IconButton}">
                <Setter Property="Height" Value="24" />
                <Setter Property="Width" Value="24" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </GroupBox.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" MaxHeight="24" />
                <RowDefinition Height="Auto" MaxHeight="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
            </Grid.ColumnDefinitions>
            <TextBlock          Grid.Column="0"
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Text="{loc:Translate Key=title}"
                            />
            <TextBox Grid.Column="0"
                     Grid.Row="1"
                     x:Name="Amount"
                     Text="{Binding Entity.Title}" />
            <xctk:IconButton   Grid.Column="1"
                           Grid.Row="1"
                           Height="24"
                           Width="24"
                           Command="{Binding ClearTitleCommand}" >
                <xctk:IconButton.Icon>
                    <Image Source="{StaticResource IconXmark}" Height="16" Width="16" />
                </xctk:IconButton.Icon>
            </xctk:IconButton>

            <CheckBox   Grid.Column="0"
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Content="{loc:Translate Key=is_active}"
                        IsChecked="{Binding Entity.IsActive}" />

            <Grid Grid.Row="3"
              Margin="0 24 0 0"
              Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Margin="2"
                        Command="{Binding SaveCommand}"
                        Content="{loc:Translate Key=save}" />
                <Button Grid.Column="1" Margin="2"
                        Command="{Binding CancelCommand}"
                        Content="{loc:Translate Key=cancel}" />
            </Grid>
        </Grid>
    </GroupBox>
</UserControl>
