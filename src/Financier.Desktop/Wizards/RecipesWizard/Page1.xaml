<UserControl x:Class="Financier.Desktop.Wizards.RecipesWizard.View.Page1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Financier.Desktop.Wizards.RecipesWizard.View"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:loc="clr-namespace:Financier.Common.Localization;assembly=Financier.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{loc:Translate Key=recipes_instructions_line1}"/>
        <Grid Grid.Column="0"
              Grid.Row="1"
              Margin="10 10 0 0"
              Height="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Width="65"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    Content="{loc:Translate Key=paste}"
                    ToolTip="{loc:Translate Key=paste_tooltip}"
                    Command="ApplicationCommands.Paste"
                    CommandTarget="{Binding ElementName=_richTextBox}"
                />
            <Button Grid.Column="1"
                    Width="65"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    Content="{loc:Translate Key=highlight}"
                    ToolTip="{loc:Translate Key=highlight_tooltip}"
                    Command="{Binding Path=HighlightCommand}"
                    CommandParameter="{Binding ElementName=_richTextBox}"
                />
            <TextBlock Grid.Column="2"
                       HorizontalAlignment="Right"
                       Text="{Binding FormattedTotal}" />
        </Grid>

        <xctk:RichTextBox x:Name="_richTextBox"
                          Grid.Row="2"
                          Margin="10"
                          BorderBrush="Gray"
                          Padding="10"
                          Text="{Binding Text, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, NotifyOnSourceUpdated=True}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
            <xctk:RichTextBox.TextFormatter>
                <local:RecipesFormatter />
            </xctk:RichTextBox.TextFormatter>
        </xctk:RichTextBox>
    </Grid>
</UserControl>
